SECRET_KEY=django-insecure-docker-secret-change-in-production
DEBUG=True
ALLOWED_HOSTS=aura-auth-service,aura-auth-service:8000,127.0.0.1,127.0.0.1:8000,localhost,localhost:8000

DB_ENGINE=django.db.backends.postgresql
DB_NAME=auth_db
DB_USER=aura_root
DB_PASSWORD=aura_password
DB_HOST=auth_db
DB_PORT=5432

AURA_DB_NAME=aura_db
AURA_DB_USER=aura_root
AURA_DB_PASSWORD=aura_password
AURA_DB_HOST=aura_db
AURA_DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

DOCUMENT_PROCESSING_URL=http://aura-document-processing-service:8000
DOCUMENT_PROCESSING_SERVICE_API_KEY=service_api_key

SERVICE_API_KEY=service_api_key
DOCUMENT_PROCESSING_TIMEOUT_SECONDS=300

NOTIFICATION_SERVICE_URL=http://aura-notification-service:8000
NOTIFICATION_INTERNAL_API_TOKEN=dev-notification-internal-token
NOTIFICATION_SERVICE_TIMEOUT_SECONDS=30

DOC_COLLECTION_SERVICE_URL=http://aura-document-collection-service:8000
DOC_COLLECTION_SERVICE_API_KEY=service_api_key

CHAT_SERVICE_URL=http://aura-chat-service:8000
LLM_SERVICE_URL=http://aura-llm-service:8000

NEO4J_HTTP_URL=http://neo4j:7474
NEO4J_HTTP_USER=neo4j
NEO4J_HTTP_PASSWORD=aura_password

RABBITMQ_MGMT_URL=http://queue:15672
RABBITMQ_MGMT_USER=aura_root
RABBITMQ_MGMT_PASSWORD=aura_password

ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── LDAP ──────────────────────────────────────────────────────────────────────
# Servidor LDAP — apunta al contenedor del docker-compose-ldap.yml
LDAP_SERVER_URI=ldap://aura-ldap:389
LDAP_BIND_DN=cn=admin,dc=aura,dc=local
LDAP_BIND_PASSWORD=admin_password
LDAP_USER_SEARCH_BASE=ou=users,dc=aura,dc=local
LDAP_EMAIL_FALLBACK_DOMAIN=ldap.local

# Nombres de atributos LDAP — ajustar al schema real del servidor corporativo
# Ejemplos para Active Directory: uid=sAMAccountName, mail=userPrincipalName
LDAP_ATTR_UID=uid
LDAP_ATTR_MAIL=mail
LDAP_ATTR_DISPLAY_NAME=displayName
LDAP_ATTR_CLASSIFICATION_LEVEL=auraClassificationLevel
LDAP_ATTR_COMPARTMENT=auraCompartment
