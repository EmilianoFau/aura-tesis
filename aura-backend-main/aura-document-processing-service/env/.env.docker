APP_NAME='aura document processing service'
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=False
REQUIRE_GPU=False
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:4200","http://127.0.0.1:4200","http://localhost:8000","http://127.0.0.1:8000","http://localhost:8001","http://127.0.0.1:8001","http://localhost:8002","http://127.0.0.1:8002","http://localhost:8003","http://127.0.0.1:8003","http://localhost:8004","http://127.0.0.1:8004","http://localhost:8005","http://127.0.0.1:8005"]
ENVIRONMENT=docker

# ===== TEXT CLEANER SETTINGS =====

TEXT_CLEANER_ACTIVE_TYPE=simple

# ===== TEXT SPLITTER SETTINGS =====

TEXT_SPLITTER_ACTIVE_TYPE=docling_hybrid

TEXT_SPLITTER_STRUCTURED_FALLBACK_TYPE=huggingface
TEXT_SPLITTER_MAX_TEXT_LENGTH=10000000

TEXT_SPLITTER_HUGGINGFACE_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
TEXT_SPLITTER_HUGGINGFACE_DEVICE=cpu
TEXT_SPLITTER_HUGGINGFACE_BREAKPOINT_THRESHOLD_TYPE=percentile
TEXT_SPLITTER_HUGGINGFACE_BREAKPOINT_THRESHOLD_AMOUNT=90
TEXT_SPLITTER_HUGGINGFACE_MAX_CHUNK_TOKENS=510
TEXT_SPLITTER_HUGGINGFACE_CHUNK_TOKEN_OVERLAP=50

TEXT_SPLITTER_MIN_CHUNK_CHARS=150

TEXT_SPLITTER_RECURSIVE_SPLIT_SIZE=800
TEXT_SPLITTER_RECURSIVE_SPLIT_OVERLAP=100
TEXT_SPLITTER_RECURSIVE_ENCODING_NAME=cl100k_base

# ----- Docling hybrid (structure-aware) splitter -----
# Models are baked into the image; point the splitter at the pre-downloaded path.
TEXT_SPLITTER_DOCLING_TOKENIZER_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
TEXT_SPLITTER_DOCLING_MAX_TOKENS=512
TEXT_SPLITTER_DOCLING_MERGE_PEERS=true
TEXT_SPLITTER_DOCLING_DEVICE=cpu
TEXT_SPLITTER_DOCLING_NUM_THREADS=4
TEXT_SPLITTER_DOCLING_ARTIFACTS_PATH=/opt/cache/huggingface/docling

# ===== READER SETTINGS =====

READER_DOCLING_ENABLED=true
READER_DOCLING_DEVICE=cpu
READER_DOCLING_NUM_THREADS=4

# ===== EMBEDDER SETTINGS =====

EMBEDDER_ACTIVE_TYPE=ollama

EMBEDDER_VECTOR_DIMENSION=1024

EMBEDDER_HUGGINGFACE_MODEL=intfloat/multilingual-e5-large
EMBEDDER_HUGGINGFACE_DEVICE=cpu
EMBEDDER_HUGGINGFACE_NORMALIZE_EMBEDDINGS=true
EMBEDDER_HUGGINGFACE_QUERY_INSTRUCTION="query: "
EMBEDDER_HUGGINGFACE_EMBED_INSTRUCTION="passage: "

EMBEDDER_MAX_BATCH_SIZE=32
EMBEDDER_MAX_TEXT_LENGTH=8000

EMBEDDER_OLLAMA_MODEL=qwen3-embedding:0.6b
EMBEDDER_OLLAMA_URL=http://llm:11434
EMBEDDER_OLLAMA_REQUEST_TIMEOUT=300

# ===== RERANKER SETTINGS =====

RERANKER_ACTIVE_TYPE=cross_encoder
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=cpu
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=1024
RERANKER_MIN_SCORE=0.35

# ===== FRAGMENT RETRIEVAL RELEVANCE SETTINGS =====

FRAGMENT_QUERY_SIMILARITY_THRESHOLD=0.50
FRAGMENT_QUERY_BM25_RRF_K=60
FRAGMENT_QUERY_BM25_MIN_SCORE=0.0
FRAGMENT_QUERY_BM25_QUERY_MAX_CHARS=512

# ===== DOCUMENT SEARCH RELEVANCE SETTINGS =====

DOCUMENT_SEARCH_SIMILARITY_THRESHOLD=0.45
DOCUMENT_SEARCH_CANDIDATE_POOL_SIZE=200

# ===== RABBITMQ MANAGER SETTINGS =====

RABBITMQ_MANAGER_URL=amqp://aura_root:aura_password@queue:5672/

# ===== REDIS CLIENT SETTINGS =====

REDIS_CLIENT_URL=redis://memory_db:6379/0

# ===== DATABASE MANAGER SETTINGS =====

DATABASE_MANAGER_DRIVER=postgresql+asyncpg
DATABASE_MANAGER_USER=aura_root
DATABASE_MANAGER_PASSWORD=aura_password
DATABASE_MANAGER_HOST=aura_db
DATABASE_MANAGER_PORT=5432
DATABASE_MANAGER_NAME=aura_db

# ===== MINIO MANAGER SETTINGS =====

MINIO_MANAGER_ENDPOINT=storage:9000
MINIO_MANAGER_ACCESS_KEY=aura_root
MINIO_MANAGER_SECRET_KEY=aura_password

# ===== AUTHENTICATION PROVIDER SETTINGS =====

AUTHENTICATION_PROVIDER_AUTHENTICATION_URL=http://aura-auth-service:8000/auth/validate

# ===== LLM PROVIDER SETTINGS =====

LLM_PROVIDER_CLASSIFY_DOCUMENT_URL=http://aura-llm-service:8000/api/v1/document-classify
LLM_PROVIDER_CONTEXTUALIZE_FRAGMENT_URL=http://aura-llm-service:8000/api/v1/fragment-contextualize
LLM_PROVIDER_EXTRACT_ENTITIES_RELATIONS_URL=http://aura-llm-service:8000/api/v1/graph-extraction
LLM_PROVIDER_TRANSLATE_GRAPH_QUERY_URL=http://aura-llm-service:8000/api/v1/graph-query-translation
LLM_PROVIDER_TIMEOUT_SECONDS=180

# ===== KNOWLEDGE GRAPH SETTINGS =====

KNOWLEDGE_GRAPH_ENABLED=true

# ===== NEO4J MANAGER SETTINGS =====

NEO4J_MANAGER_URI=neo4j://neo4j:7687
NEO4J_MANAGER_USER=neo4j
NEO4J_MANAGER_PASSWORD=aura_password
NEO4J_MANAGER_DATABASE=neo4j

# ===== DOCUMENT COLLECTION SERVICE =====

DOCUMENT_COLLECTION_SERVICE_ACCESSIBLE_COLLECTIONS_URL=http://aura-document-collection-service:8000/api/v1/user-authorizations

# ===== CHAT SERVICE =====

CHAT_SERVICE_MEMBERSHIP_URL=http://aura-chat-service:8000/api/v1
