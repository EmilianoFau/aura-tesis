DJANGO_SETTINGS_MODULE=aura_chat_service.settings.development
LOG_LEVEL=DEBUG
SECRET_KEY=django-insecure-docker-chat-change-in-production
DEBUG=True
ALLOWED_HOSTS=aura-chat-service,aura-chat-service:8000,127.0.0.1,127.0.0.1:8000,localhost,localhost:8000

# Restrict CORS to the frontend origins below instead of allowing every origin.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

DB_NAME=aura_db
DB_USER=aura_root
DB_PASSWORD=aura_password
DB_HOST=aura_db
DB_PORT=5432

REDIS_URL=redis://memory_db:6379/0

AUTHENTICATION_SERVICE_URL=http://aura-auth-service:8000/auth/validate

LLM_DOCUMENT_QUESTION_URL=http://aura-llm-service:8000/api/v1/document-question
LLM_DOCUMENT_QUESTION_STREAM_URL=http://aura-llm-service:8000/api/v1/document-question/stream
LLM_GENERAL_CHAT_URL=http://aura-llm-service:8000/api/v1/general-chat
LLM_GENERAL_CHAT_STREAM_URL=http://aura-llm-service:8000/api/v1/general-chat/stream
LLM_RAG_AGENT_URL=http://aura-llm-service:8000/api/v1/rag-agent
LLM_RAG_AGENT_STREAM_URL=http://aura-llm-service:8000/api/v1/rag-agent/stream
LLM_CHECKLIST_GENERATE_URL=http://aura-llm-service:8000/api/v1/checklist-generate
LLM_CHECKLIST_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/checklist-generate/stream
LLM_REPORT_GENERATE_URL=http://aura-llm-service:8000/api/v1/report-generate
LLM_REPORT_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/report-generate/stream
LLM_TIMELINE_GENERATE_URL=http://aura-llm-service:8000/api/v1/timeline-generate
LLM_TIMELINE_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/timeline-generate/stream
LLM_QUIZ_GENERATE_URL=http://aura-llm-service:8000/api/v1/quiz-generate
LLM_QUIZ_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/quiz-generate/stream
LLM_LESSONS_LEARNED_GENERATE_URL=http://aura-llm-service:8000/api/v1/lessons-learned-generate
LLM_LESSONS_LEARNED_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/lessons-learned-generate/stream
LLM_DECISION_BRIEF_GENERATE_URL=http://aura-llm-service:8000/api/v1/decision-brief-generate
LLM_DECISION_BRIEF_GENERATE_STREAM_URL=http://aura-llm-service:8000/api/v1/decision-brief-generate/stream
LLM_DOCUMENT_SUMMARY_URL=http://aura-llm-service:8000/api/v1/document-summary
LLM_DOCUMENT_SUMMARY_STREAM_URL=http://aura-llm-service:8000/api/v1/document-summary/stream
LLM_DOCUMENT_ACTION_URL=http://aura-llm-service:8000/api/v1/document-action
LLM_DOCUMENT_ACTION_STREAM_URL=http://aura-llm-service:8000/api/v1/document-action/stream
LLM_FEEDBACK_EVALUATION_URL=http://aura-llm-service:8000/api/v1/feedback-evaluate

NOTIFICATION_SERVICE_URL=http://aura-notification-service:8000
NOTIFICATION_INTERNAL_API_TOKEN=dev-notification-internal-token

DOCUMENT_PROCESSING_SERVICE_URL=http://aura-document-processing-service:8000

# ===== WHISPER (TRANSCRIPTION) SETTINGS =====
# WHISPER_MODEL_SIZE must match the WHISPER_MODEL_SIZE build arg in the
# Dockerfile so the model baked into the image is the one actually used.
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_PRELOAD=True
