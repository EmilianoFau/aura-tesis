@llmBase = http://localhost:8001/api/v1
@authToken = user_token_123
@chatId = 1

### Generar checklist — JSON (POST /api/v1/checklist-generate)
# @timeout 600
POST {{llmBase}}/checklist-generate
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Procedimiento de inspección pre-vuelo: revisar tren de aterrizaje, niveles de fluidos, superficies de control y radio."
    }
  ],
  "chat_id": {{chatId}}
}


### Generar checklist — Streaming SSE (POST /api/v1/checklist-generate/stream)
# @timeout 600
POST {{llmBase}}/checklist-generate/stream
Accept: text/event-stream
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Extraé los pasos del procedimiento del documento adjunto."
    }
  ],
  "chat_id": {{chatId}},
  "document_ids": [10],
  "retrieve_context": true
}
