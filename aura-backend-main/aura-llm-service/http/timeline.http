@llmBase = http://localhost:8001/api/v1
@authToken = user_token_123
@chatId = 1

### Generar línea de tiempo — JSON (POST /api/v1/timeline-generate)
# @timeout 600
POST {{llmBase}}/timeline-generate
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "A las 0600 inició la patrulla. A las 0830 se detectó actividad en el sector este. A las 0900 se reportó al comando. A las 1000 se replegó la unidad."
    }
  ],
  "chat_id": {{chatId}}
}


### Generar línea de tiempo — Streaming SSE (POST /api/v1/timeline-generate/stream)
# @timeout 600
POST {{llmBase}}/timeline-generate/stream
Accept: text/event-stream
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Reconstruí la cronología de los hechos descritos en el parte adjunto."
    }
  ],
  "chat_id": {{chatId}},
  "document_ids": [10],
  "retrieve_context": true
}
