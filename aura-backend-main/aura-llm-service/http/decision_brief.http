@llmBase = http://localhost:8001/api/v1
@authToken = user_token_123
@chatId = 1

### Generar brief de decisión — JSON (POST /api/v1/decision-brief-generate)
# @timeout 600
POST {{llmBase}}/decision-brief-generate
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Necesitamos decidir entre reforzar el sector este con la reserva o mantenerla en posición. Recursos limitados y clima adverso previsto."
    }
  ],
  "chat_id": {{chatId}}
}


### Generar brief de decisión — Streaming SSE (POST /api/v1/decision-brief-generate/stream)
# @timeout 600
POST {{llmBase}}/decision-brief-generate/stream
Accept: text/event-stream
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Elaborá el brief ejecutivo de decisión a partir del análisis adjunto."
    }
  ],
  "chat_id": {{chatId}},
  "document_ids": [10],
  "retrieve_context": true
}
