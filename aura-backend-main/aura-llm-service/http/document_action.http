@llmBase = http://localhost:8001/api/v1
@authToken = user_token_123
@chatId = 1

### Acción sobre documento — summarize (POST /api/v1/document-action)
# @timeout 600
POST {{llmBase}}/document-action
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "document_ids": [10],
  "instruction": "Resumime el contenido de este documento",
  "action": "summarize",
  "chat_id": {{chatId}}
}


### Acción sobre documento — Streaming SSE (POST /api/v1/document-action/stream)
# @timeout 600
POST {{llmBase}}/document-action/stream
Accept: text/event-stream
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "document_ids": [10],
  "instruction": "Resumime el contenido de este documento",
  "action": "summarize",
  "chat_id": {{chatId}}
}


