@llmBase = http://localhost:8001/api/v1
@authToken = user_token_123
@chatId = 1

### Generar lecciones aprendidas — JSON (POST /api/v1/lessons-learned-generate)
# @timeout 600
POST {{llmBase}}/lessons-learned-generate
Accept: application/json
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Durante el ejercicio se demoró la comunicación entre unidades por falta de un canal de respaldo, lo que retrasó el repliegue."
    }
  ],
  "chat_id": {{chatId}}
}


### Generar lecciones aprendidas — Streaming SSE (POST /api/v1/lessons-learned-generate/stream)
# @timeout 600
POST {{llmBase}}/lessons-learned-generate/stream
Accept: text/event-stream
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "messages": [
    {
      "role": "human",
      "content": "Hacé el análisis post-acción de la operación descrita en el informe adjunto."
    }
  ],
  "chat_id": {{chatId}},
  "document_ids": [10],
  "retrieve_context": true
}
